# Hsociety Server - copy to .env in this directory (server/)
# Or set in repo root .env when running server from root

PORT=3000
FRONTEND_URL=http://localhost:5173
# PAYSTACK_SECRET_KEY=sk_test_xxxx
# BOOTCAMP_PRICE_GHS=150
# BOOTCAMP_CURRENCY=GHS
# Comma-separated list for production CORS origins (Netlify/Vercel/custom domains)
# FRONTEND_URLS=https://your-site.netlify.app,https://your-custom-domain.com
MONGODB_URI=mongodb://localhost:27017/hsociety

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Admin seed (optional)
ADMIN_EMAIL=admin@hsociety.local
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Mr. Robot
ADMIN_ORG=HSOCIETY

# Paid student seed for workspace testing (optional, disabled by default)
SEED_PAID_STUDENT=false
SEED_PAID_STUDENT_NAME=h4ck3r10
SEED_PAID_STUDENT_PASSWORD=test School
SEED_PAID_STUDENT_EMAIL=h4ck3r10@hsociety.local

# Twilio – OTP SMS (optional; if unset, OTP is logged to console only)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+15551234567
# TWILIO_DEFAULT_COUNTRY_CODE=1
